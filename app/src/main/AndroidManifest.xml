<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.AfritextExchange">

        <activity android:name=".activities.SplashActivity"
            android:theme="@style/Theme.AfritextExchange.Splash"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".activities.RegisterActivity" android:exported="false"/>
        <activity android:name=".activities.HomeActivity"     android:exported="false"/>
        <activity android:name=".activities.SearchActivity"   android:exported="false"/>
        <activity android:name=".activities.BookDetailActivity" android:exported="false"/>
        <activity android:name=".activities.AddListingActivity" android:exported="false"/>
        <activity android:name=".activities.EnquiryActivity"  android:exported="false"/>
        <activity android:name=".activities.SearchActivity" android:exported="false"
            tools:ignore="DuplicateActivity" />

    </application>
</manifest>